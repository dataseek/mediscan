## Base
OPENROUTER_API_KEY=

## OCR dedicado opcional
## Si se configura GOOGLE_CLOUD_VISION_API_KEY, MediScan usa Google Vision OCR antes de la IA.
## Si no existe Google Vision pero existe OCR_SPACE_API_KEY, usa OCR.Space como fallback.
GOOGLE_CLOUD_VISION_API_KEY=
OCR_SPACE_API_KEY=

## Farmacias cercanas (opcional)
## Si se configura GOOGLE_MAPS_API_KEY, MediScan usa Google Maps Places.
GOOGLE_MAPS_API_KEY=


## Auth.js / NextAuth (v5 beta)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

## OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

## Email (Resend) - magic link + transactional emails
RESEND_API_KEY=
RESEND_FROM_EMAIL="MediScan <no-reply@yourdomain.com>"

## Database (PostgreSQL)
DATABASE_URL=

## Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:3000/cuenta

